# Copy to .env.local and add your real OpenAI API key.
# Get one at https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-proj-your-real-key-here

# Optional — public URLs for docs/app cross-links
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Docs default to /docs on the same host. Set this only for a custom docs subdomain.
# NEXT_PUBLIC_DOCS_URL=https://docs.yourdomain.com
